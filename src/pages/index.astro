---
import Layout from "../layouts/Layout.astro";
//import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Education from "../components/Education.astro";
import Contact from "../components/Contact.astro";
import fs from "fs";
import path from "path";
// @ts-ignore
import matter from "gray-matter";

// Read projects directly from files
const projectsDir = path.join(process.cwd(), "src", "content", "projects");
const projects: {
	slug: string;
	data: {
		title: string;
		description: string;
		technologies: string[];
		stars: number;
		featured: boolean;
		order: number;
		date: Date;
		githubUrl: string;
		liveUrl: string;
		behanceUrl: string; // ← Add this
		image: string;
	};
}[] = [];

try {
	const files = fs.readdirSync(projectsDir);

	for (const file of files) {
		if (file.endsWith(".md")) {
			const filePath = path.join(projectsDir, file);
			const content = fs.readFileSync(filePath, "utf-8");
			const { data } = matter(content);

			projects.push({
				slug: file.replace(".md", ""),
				data: {
					title: data.title || "Untitled",
					description: data.description || "",
					technologies: data.technologies || [],
					stars: data.stars || 0,
					featured: data.featured || false,
					order: data.order || 0,
					date: data.date || new Date(),
					githubUrl: data.githubUrl || "",
					liveUrl: data.liveUrl || "",
					behanceUrl: data.behanceUrl || "", // ← Add this
					image: data.image || "",
				},
			});
		}
	}
} catch (error) {
	console.error("Error reading projects:", error);
}

// Sort projects by order
projects.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const featuredProjects = projects.filter((p) => p.data.featured);

// Education data
const educationData = [
	{
		institution: "Syrian Virtual University",
		degree: "M.Sc. in Web Science",
		field: "Web Science",
		period: "2023 — 2026",
		description:
			"Researching and building intelligent web systems. Thesis focuses on Sientific Claims verification.",
		achievements: [
			"Thesis: Identifying unsubstantiated claims in scientific research using artificial intelligence algorithms",
		],
	},
];

/* const aboutContent = [
	"I'm a developer who specializes in building real-time, interactive web systems. Over the past 4+ years, I've worked extensively with clinics and universities, creating custom solutions that streamline complex workflows.",

	"I've delivered 15+ client projects, from legacy system migrations to modern web applications. My focus is always on clean code, user experience, and real impact—whether that's reducing appointment wait times or making data accessible across departments.",

	"Beyond clinics, I've worked on university systems, IT infrastructure upgrades, and mentoring junior developers. I'm passionate about solving hard problems and building technology that makes a difference.",
]; */
const aboutContent = [
	"I build scalable web systems with Laravel, Livewire, and PHP/MySQL. My work includes real-time clinic management systems, queue platforms, and financial audit tools.",
	"Beyond development, I also design websites—you can see my web design work on Behance.",
	"Currently completing my M.Sc. in Web Science, researching intelligent systems for healthcare.",
];

const skills = [
	// Core Stack
	"Laravel",
	"Livewire",
	"PHP",
	"MySQL",
	"Oracle",
	"JavaScript (ES6+)",

	// Frontend
	//"React",
	"CSS",
	//"TypeScript",

	// Specialization (add this!)
	"Real-time Applications",
	"Single-Page Applications (SPA)",
	"Clinic Management Systems",
	"Legacy System Migration",

	// Tools & Practices
	"Git",
	"cPanel",
	"Toad for Oracle",
	"REST APIs",
	"WordPress",
	"Linux (CLI)",
	"Apache",

	// Testing & Quality
	//"Pest / PHPUnit",
	"System Architecture",
	"IT Infrastructure",
];
---

<Layout title="Aalaa Al Jaddoaa">
	<!-- <Navbar /> -->

	<!-- Left Sidebar - Wrapped in sidebar-wrapper -->
	<div class="sidebar-wrapper">
		<Sidebar
			name="Aalaa Al Jaddoaa"
			title="Full Stack Developer & Creative Thinker"
		/>
	</div>

	<!-- Main Content -->
	<div class="main-content">
		<!-- Hero Section -->
		<Hero
			name="Aalaa,"
			title="Full Stack Developer & Creative Thinker"
			tagline="I craft digital experiences that are as beautiful as they are functional. Let's build something amazing together."
		/>

		<!-- About Section -->
		<section id="about" class="about-section">
			<About content={aboutContent} skills={skills} />
		</section>

		<!-- Experience/Education Section -->
		<!-- <section id="experience" class="experience-section">
			<Education items={educationData} />
		</section> -->

		<!-- Projects Section -->
		<section id="projects" class="projects section animate-fade-in-up">
			<div class="section-label">
				<h2>Projects</h2>
				<div class="line"></div>
			</div>

			<!-- Brief intro -->
			<p class="projects-intro">
				Here are my main development projects. You can also view my <a
					href="https://behance.net/yourusername"
					target="_blank"
					class="behance-link">website designs on Behance</a
				> →
			</p>

			<!-- Featured Projects -->
			{
				featuredProjects.length > 0 && (
					<div class="featured-grid">
						{featuredProjects.map((project, index) => (
							<div
								class="featured-card"
								style={`animation-delay: ${index * 0.1}s`}
							>
								<div class="featured-header">
									<span class="featured-icon">✦</span>
									<span class="featured-badge">Featured</span>
								</div>
								<h3>{project.data.title}</h3>
								<p>{project.data.description}</p>
								<div class="project-tags">
									{project.data.technologies.map(
										(tech: string) => (
											<span class="tag">{tech}</span>
										),
									)}
								</div>
								<div class="project-links">
									{project.data.githubUrl && (
										<a
											href={project.data.githubUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="project-link github"
										>
											<i class="fab fa-github" /> GitHub
										</a>
									)}
									{project.data.behanceUrl && (
										<a
											href={project.data.behanceUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="project-link behance"
										>
											<i class="fab fa-behance" /> Behance
										</a>
									)}
									{project.data.liveUrl && (
										<a
											href={project.data.liveUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="project-link live"
										>
											<i class="fas fa-external-link-alt" />{" "}
											Live Demo
										</a>
									)}
								</div>
								{project.data.stars > 0 && (
									<div style="margin-top: 0.5rem; color: var(--text-muted); font-size: 0.85rem;">
										<i
											class="fas fa-star"
											style="color: #f59e0b;"
										/>{" "}
										{project.data.stars}
									</div>
								)}
							</div>
						))}
					</div>
				)
			}

			<!-- Regular Projects (excluding featured) -->
			{
				projects.filter((p) => !p.data.featured).length > 0 && (
					<div class="project-grid">
						{projects
							.filter((project) => !project.data.featured)
							.map((project, index) => (
								<div
									class="project-card"
									style={`animation-delay: ${index * 0.1}s`}
								>
									<h3>{project.data.title}</h3>
									<p>{project.data.description}</p>
									<div class="project-tags">
										{project.data.technologies.map(
											(tech: string) => (
												<span class="tag">{tech}</span>
											),
										)}
									</div>
									<div class="project-links">
										{project.data.githubUrl && (
											<a
												href={project.data.githubUrl}
												target="_blank"
												rel="noopener noreferrer"
												class="project-link github"
											>
												<i class="fab fa-github" />
											</a>
										)}
										{project.data.behanceUrl && (
											<a
												href={project.data.behanceUrl}
												target="_blank"
												rel="noopener noreferrer"
												class="project-link behance"
											>
												<i class="fab fa-behance" />
											</a>
										)}
										{project.data.liveUrl && (
											<a
												href={project.data.liveUrl}
												target="_blank"
												rel="noopener noreferrer"
												class="project-link live"
											>
												<i class="fas fa-external-link-alt" />
											</a>
										)}
									</div>
									{project.data.stars > 0 && (
										<div class="project-stats">
											<span>
												<i class="fas fa-star" />{" "}
												{project.data.stars}
											</span>
										</div>
									)}
								</div>
							))}
					</div>
				)
			}
		</section>

		<!-- Contact Section -->
		<section id="contact">
			<Contact />
		</section>
	</div>
</Layout>

<style>
	.projects {
		padding: 4rem 0;
		scroll-margin-top: 80px;
	}

	.section-label {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 2.5rem;
	}

	.section-label h2 {
		font-size: 1.8rem;
		font-weight: 700;
		background: var(--gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.section-label .line {
		flex: 1;
		height: 2px;
		background: linear-gradient(to right, var(--accent), transparent);
	}

	.featured-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.featured-card {
		background: var(--bg-card);
		padding: 1.8rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		text-decoration: none;
		color: inherit;
		transition: all 0.4s ease;
		opacity: 0;
		animation: fadeInUp 0.8s ease-out forwards;
		position: relative;
		overflow: hidden;
	}

	.featured-card:hover {
		transform: translateY(-6px);
		border-color: var(--accent);
		box-shadow: 0 12px 40px var(--shadow);
	}

	.featured-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--gradient);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.featured-card:hover::before {
		opacity: 1;
	}

	.featured-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.8rem;
	}

	.featured-icon {
		font-size: 1.5rem;
		color: var(--accent);
	}

	.featured-badge {
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--accent);
		background: rgba(108, 99, 255, 0.1);
		padding: 0.2rem 0.8rem;
		border-radius: 6px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.featured-card h3 {
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.featured-card p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-family: "JetBrains Mono", monospace;
		font-size: 0.65rem;
		color: var(--text-muted);
		background: var(--bg-primary);
		padding: 0.2rem 0.8rem;
		border-radius: 6px;
		border: 1px solid var(--border);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.project-card {
		background: var(--bg-card);
		padding: 1.5rem;
		border-radius: 12px;
		border: 1px solid var(--border);
		text-decoration: none;
		color: inherit;
		transition: all 0.3s ease;
		opacity: 0;
		animation: fadeInUp 0.8s ease-out forwards;
	}

	.project-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent);
		box-shadow: 0 8px 30px var(--shadow);
	}

	.project-card h3 {
		font-size: 1.1rem;
		font-weight: 600;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.project-card p {
		color: var(--text-secondary);
		font-size: 0.9rem;
		line-height: 1.6;
		margin-bottom: 1rem;
	}

	.project-stats {
		margin-top: 0.5rem;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.project-stats i {
		color: #f59e0b;
		margin-right: 0.3rem;
	}

	/* Project Links */
	.project-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 0.8rem;
		padding-top: 0.8rem;
		border-top: 1px solid var(--border);
	}

	.project-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.8rem;
		padding: 0.3rem 0.8rem;
		border-radius: 6px;
		text-decoration: none;
		transition: all 0.3s ease;
		font-weight: 500;
	}

	.project-link.github {
		color: #fff;
		background: #24292e;
	}

	.project-link.github:hover {
		background: #3a3f47;
		transform: translateY(-2px);
	}

	.project-link.behance {
		color: #fff;
		background: #1769ff;
	}

	.project-link.behance:hover {
		background: #1a7aff;
		transform: translateY(-2px);
	}

	.project-link.live {
		color: var(--accent);
		background: rgba(108, 99, 255, 0.1);
		border: 1px solid var(--accent);
	}

	.project-link.live:hover {
		background: rgba(108, 99, 255, 0.2);
		transform: translateY(-2px);
	}

	/* Featured card project links */
	.featured-card .project-links {
		margin-top: 1rem;
	}

	/* Project card links (smaller icons) */
	.project-card .project-links {
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.project-card .project-link {
		padding: 0.2rem 0.5rem;
		font-size: 0.75rem;
	}

	.projects-intro {
		color: var(--text-secondary);
		font-size: 0.95rem;
		margin-bottom: 2rem;
		padding: 1rem 1.5rem;
		background: var(--bg-card);
		border-radius: 8px;
		border-left: 3px solid var(--accent);
	}

	.projects-intro a {
		color: var(--accent);
		text-decoration: none;
		font-weight: 500;
		transition: opacity 0.2s ease;
	}

	.projects-intro a:hover {
		opacity: 0.7;
	}

	.behance-note {
		display: inline-block;
		margin-top: 0.5rem;
		padding: 0.3rem 0.8rem;
		background: rgba(23, 105, 255, 0.1);
		border-radius: 6px;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.behance-note i {
		color: #1769ff;
		margin-right: 0.4rem;
	}

	.behance-note a {
		color: #1769ff;
		text-decoration: none;
	}

	.behance-note a:hover {
		text-decoration: underline;
	}
</style>
