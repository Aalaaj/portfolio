---
interface Props {
    title: string;
    id?: string;
}

const { title, id } = Astro.props;
---

<div id={id} class="section-header">
    <div class="section-label">
        <h2>{title}</h2>
        <div class="line-wrapper">
            <div class="line"></div>
            <div class="line-wave"></div>
        </div>
    </div>
</div>

<style>
    .section-header {
        margin-bottom: 2.5rem;
        scroll-margin-top: 80px;
    }
    
    .section-label {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    
    .section-label h2 {
        font-size: 1.8rem;
        font-weight: 700;
        background: var(--gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-size: 200% auto;
        animation: gradientShift 4s ease infinite;
        transition: transform 0.3s ease;
        cursor: pointer;
    }
    
    .section-label h2:hover {
        transform: scale(1.02);
    }
    
    .line-wrapper {
        flex: 1;
        height: 3px;
        position: relative;
        overflow: hidden;
        border-radius: 2px;
        cursor: pointer;
    }
    
    .line {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 100%;
        background: linear-gradient(to right, var(--accent), transparent);
        opacity: 0.5;
        transition: opacity 0.3s ease;
    }
    
    .line-wave {
        position: absolute;
        top: 0;
        left: -100%;
        width: 200%;
        height: 100%;
        background: linear-gradient(
            to right,
            transparent,
            var(--accent) 20%,
            var(--accent-hover) 40%,
            var(--accent) 60%,
            transparent 80%
        );
        background-size: 200% 100%;
        opacity: 0;
        transition: opacity 0.3s ease;
        animation: none;
    }
    
    /* Hover effects */
    .line-wrapper:hover .line {
        opacity: 0.2;
    }
    
    .line-wrapper:hover .line-wave {
        opacity: 1;
        animation: waveFlow 1.2s ease-in-out infinite;
    }
    
    /* Wave animation */
    @keyframes waveFlow {
        0% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(25%);
        }
        100% {
            transform: translateX(0);
        }
    }
    
    @keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
</style>