---
import type { CollectionEntry } from "astro:content";

interface Props {
    projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
const featuredProjects = projects.filter((p) => p.data.featured);
---

<section id="projects" class="projects section animate-fade-in-up">
    <div class="section-label">
        <h2>Projects</h2>
        <div class="line"></div>
    </div>

    {
        featuredProjects.length > 0 && (
            <div class="featured-grid">
                {featuredProjects.map((project, index) => (
                    <a
                        href={`/projects/${(project as any).slug}`}
                        class="featured-card"
                        style={`animation-delay: ${index * 0.1}s`}
                    >
                        <div class="featured-header">
                            <span class="featured-icon">✦</span>
                            <span class="featured-badge">Featured</span>
                        </div>
                        <h3>{project.data.title}</h3>
                        <p>{project.data.description}</p>
                        <div class="project-tags">
                            {project.data.technologies.map((tech: string) => (
                                <span class="tag">{tech}</span>
                            ))}
                        </div>
                        <div class="project-links">
                            {project.data.githubUrl && (
                                <span class="link-icon">
                                    <i class="fab fa-github" />
                                </span>
                            )}
                            {project.data.liveUrl && (
                                <span class="link-icon">
                                    <i class="fas fa-external-link-alt" />
                                </span>
                            )}
                            <span class="view-project">View Project →</span>
                        </div>
                    </a>
                ))}
            </div>
        )
    }

    <div class="project-grid">
        {
            projects.map((project, index) => (
                <a
                    href={`/projects/${(project as any).slug}`}
                    class="featured-card"
                    style={`animation-delay: ${index * 0.1}s`}
                >
                    <h3>{project.data.title}</h3>
                    <p>{project.data.description}</p>
                    <div class="project-tags">
                        {project.data.technologies.map((tech: string) => (
                            <span class="tag">{tech}</span>
                        ))}
                    </div>
                    {project.data.stars > 0 && (
                        <div class="project-stats">
                            <span>
                                <i class="fas fa-star" /> {project.data.stars}
                            </span>
                        </div>
                    )}
                </a>
            ))
        }
    </div>
</section>

<style>
    .projects {
        padding: 4rem 0;
        scroll-margin-top: 80px;
    }

    .featured-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .featured-card {
        background: var(--bg-card);
        padding: 1.8rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: inherit;
        transition: all 0.4s ease;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
        position: relative;
        overflow: hidden;
    }

    .featured-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gradient);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .featured-card:hover::before {
        opacity: 1;
    }

    .featured-card:hover {
        transform: translateY(-6px);
        border-color: var(--accent);
        box-shadow: 0 12px 40px var(--shadow);
    }

    .featured-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.8rem;
    }

    .featured-icon {
        font-size: 1.5rem;
        color: var(--accent);
    }

    .featured-badge {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--accent);
        background: rgba(108, 99, 255, 0.1);
        padding: 0.2rem 0.8rem;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .featured-card h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .featured-card p {
        color: var(--text-secondary);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .tag {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.65rem;
        color: var(--text-muted);
        background: var(--bg-primary);
        padding: 0.2rem 0.8rem;
        border-radius: 6px;
        border: 1px solid var(--border);
    }

    .project-links {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid var(--border);
    }

    .link-icon {
        color: var(--text-muted);
        transition: color 0.3s ease;
        font-size: 0.9rem;
    }

    .featured-card:hover .link-icon {
        color: var(--accent);
    }

    .view-project {
        margin-left: auto;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--accent);
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .project-card {
        background: var(--bg-card);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
    }

    .project-card:hover {
        transform: translateY(-4px);
        border-color: var(--accent);
        box-shadow: 0 8px 30px var(--shadow);
    }

    .project-card h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .project-card p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .project-stats {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .project-stats i {
        color: #f59e0b;
        margin-right: 0.3rem;
    }
</style>
